# Kasi P.O.S — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Paystack Payment Gateway ────────────────────────────────────────────────
# Get your keys from https://dashboard.paystack.com/#/settings/developer
# Test keys  : sk_test_...  /  pk_test_...
# Live keys  : sk_live_...  /  pk_live_...

# Backend only — NEVER expose this in frontend code
PAYSTACK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Frontend-safe public key (not used in server-side flow, kept for reference)
PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE

# Webhook secret — used to verify the HMAC-SHA512 signature on incoming webhooks
# Set this to any strong random string; configure the same value in your Paystack dashboard
PAYSTACK_WEBHOOK_SECRET=

# ─── App Base URL (used for Paystack callback_url) ───────────────────────────
# Paystack redirects to: {APP_BASE_URL}/subscription?reference=xxx&trxref=xxx
# For local dev use ngrok: https://ngrok.com  →  ngrok http 8080
# Then set this to: https://abc123.ngrok.io
# For production: https://pos.yourbusiness.co.za
APP_BASE_URL=

# ─── Paystack webhook endpoint ───────────────────────────────────────────────
# Register this URL in your Paystack dashboard under Settings → API & Webhooks
# For local dev : https://abc123.ngrok.io/api/paystack/webhook
# For production: https://pos.yourbusiness.co.za/api/paystack/webhook

# ─── Test card (Paystack test mode) ──────────────────────────────────────────
# Card number : 4084 0840 8408 4081  (Paystack test Visa)
# Expiry      : any future date
# CVV         : 408
# PIN         : 0000  (if prompted)
# OTP         : 123456  (if prompted)
# Note: test transactions do NOT appear in the live dashboard

# ─── Supabase Cloud Database ────────────────────────────────────────────────
# Get your keys from Supabase Dashboard → Project Settings → API
# URL: https://najaumlvalnwybstqrcx.supabase.co

# Frontend-safe: anon/public key
VITE_SUPABASE_URL=https://najaumlvalnwybstqrcx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-key-here

# Backend-only: service_role key (for admin operations, keep secret!)
SUPABASE_SERVICE_KEY=eyJhbG...your-service-key-here

# ─── Resend Email Service ──────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys (free: 3,000 emails/month)
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# From address (must be verified domain or use onboarding@resend.dev for testing)
EMAIL_FROM=Kasi P.O.S <noreply@kasipos.co.za>
EMAIL_REPLY_TO=support@kasipos.co.za
